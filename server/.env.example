# Copy to .env and set MONITOR_DIR to this directory's ABSOLUTE host path.
# The web admin regenerates this file when you change retention settings,
# but MONITOR_DIR must be correct before the first `docker compose up`.

# Absolute host path of this server/ directory (where docker-compose.yml lives).
MONITOR_DIR=/opt/monitor

# Prometheus on-disk retention. time OR size caps the TSDB ("0" disables a cap).
PROM_RETENTION_TIME=15d
PROM_RETENTION_SIZE=0

# Per-container stdout/stderr log rotation (json-file driver) for this stack.
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3

# Grafana admin credentials (change in production).
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin

# Published host ports. Change any that conflict with existing services
# (e.g. CADVISOR_PORT=8081 if 8080 is already in use). Internal service-to-service
# scrape targets are unaffected — only the host-published port changes.
ADMIN_PORT=8088
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
DCGM_PORT=9400
NODE_EXPORTER_PORT=9100
CADVISOR_PORT=8080
