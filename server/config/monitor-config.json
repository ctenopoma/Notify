{
  "global": {
    "scrape_interval": "15s",
    "evaluation_interval": "15s"
  },
  "retention": {
    "prometheus_time": "15d",
    "prometheus_size": "0",
    "loki_period": "168h",
    "log_max_size": "10m",
    "log_max_file": "3"
  },
  "alertmanager": {
    "resolve_timeout": "5m",
    "group_wait": "10s",
    "group_interval": "10s",
    "repeat_interval": "1h",
    "heartbeat": true,
    "heartbeat_alert": "AlwaysFiringTest"
  },
  "node_exporter": {
    "enabled": true
  },
  "cadvisor": {
    "enabled": true
  },
  "gpu": {
    "enabled": true,
    "counters": [
      {
        "field": "DCGM_FI_DEV_GPU_TEMP",
        "type": "gauge",
        "help": "GPU temperature (C)."
      },
      {
        "field": "DCGM_FI_DEV_MEMORY_TEMP",
        "type": "gauge",
        "help": "Memory temperature (C)."
      },
      {
        "field": "DCGM_FI_DEV_POWER_USAGE",
        "type": "gauge",
        "help": "Power draw (W)."
      },
      {
        "field": "DCGM_FI_DEV_SM_CLOCK",
        "type": "gauge",
        "help": "SM clock (MHz)."
      },
      {
        "field": "DCGM_FI_DEV_THERMAL_VIOLATION",
        "type": "counter",
        "help": "Throttling duration due to thermal constraints (us)."
      },
      {
        "field": "DCGM_FI_DEV_POWER_VIOLATION",
        "type": "counter",
        "help": "Throttling duration due to power constraints (us)."
      },
      {
        "field": "DCGM_FI_DEV_GPU_UTIL",
        "type": "gauge",
        "help": "GPU utilization (%)."
      },
      {
        "field": "DCGM_FI_PROF_GR_ENGINE_ACTIVE",
        "type": "gauge",
        "help": "Ratio of time the graphics/compute engine is active (0-1)."
      },
      {
        "field": "DCGM_FI_PROF_SM_ACTIVE",
        "type": "gauge",
        "help": "Ratio of cycles an SM has at least 1 warp assigned (0-1)."
      },
      {
        "field": "DCGM_FI_PROF_SM_OCCUPANCY",
        "type": "gauge",
        "help": "Ratio of resident warps to the theoretical maximum (0-1)."
      },
      {
        "field": "DCGM_FI_PROF_PIPE_TENSOR_ACTIVE",
        "type": "gauge",
        "help": "Ratio of cycles the tensor (HMMA) pipe is active (0-1)."
      },
      {
        "field": "DCGM_FI_PROF_DRAM_ACTIVE",
        "type": "gauge",
        "help": "Ratio of cycles the device memory interface is active (0-1)."
      },
      {
        "field": "DCGM_FI_DEV_FB_TOTAL",
        "type": "gauge",
        "help": "Framebuffer memory total (MiB)."
      },
      {
        "field": "DCGM_FI_DEV_FB_FREE",
        "type": "gauge",
        "help": "Framebuffer memory free (MiB)."
      },
      {
        "field": "DCGM_FI_DEV_FB_USED",
        "type": "gauge",
        "help": "Framebuffer memory used (MiB)."
      },
      {
        "field": "DCGM_FI_DEV_FB_RESERVED",
        "type": "gauge",
        "help": "Framebuffer memory reserved (MiB)."
      },
      {
        "field": "DCGM_FI_PROF_NVLINK_TX_BYTES",
        "type": "gauge",
        "help": "NVLink bytes transmitted (per second)."
      },
      {
        "field": "DCGM_FI_PROF_NVLINK_RX_BYTES",
        "type": "gauge",
        "help": "NVLink bytes received (per second)."
      },
      {
        "field": "DCGM_FI_PROF_PCIE_TX_BYTES",
        "type": "gauge",
        "help": "PCIe bytes transmitted (per second)."
      },
      {
        "field": "DCGM_FI_PROF_PCIE_RX_BYTES",
        "type": "gauge",
        "help": "PCIe bytes received (per second)."
      }
    ]
  },
  "containers": [
    {
      "name": "vllm",
      "scrape": true,
      "metrics_path": "/metrics",
      "target": "vllm:8000",
      "cadvisor_liveness": true,
      "absent_alert": true,
      "logs": true,
      "log_patterns": "(?i)error|exception|cuda|out of memory",
      "log_threshold": 0
    },
    {
      "name": "litellm",
      "scrape": true,
      "metrics_path": "/metrics",
      "target": "litellm:4000",
      "cadvisor_liveness": true,
      "absent_alert": true,
      "logs": true,
      "log_patterns": "(?i)error|exception",
      "log_threshold": 0
    }
  ],
  "custom_jobs": [],
  "alerts": [
    {
      "group": "gpu_health",
      "name": "GPUMemoryHigh",
      "expr": "(DCGM_FI_DEV_FB_USED / DCGM_FI_DEV_FB_TOTAL) * 100 > 95",
      "for": "5m",
      "severity": "warning",
      "summary": "GPU{{ $labels.gpu }} の VRAM 使用率が高い ({{ $value | printf \"%.0f\" }}%)",
      "description": "FB 使用率が閾値超で5分継続。OOM/断片化のリスク。vLLM の gpu_cache_usage_perc も併せて確認してください。",
      "enabled": true
    },
    {
      "group": "gpu_health",
      "name": "GPUNVLinkSaturated",
      "expr": "(DCGM_FI_PROF_NVLINK_TX_BYTES + DCGM_FI_PROF_NVLINK_RX_BYTES) > 20e9",
      "for": "5m",
      "severity": "warning",
      "summary": "GPU{{ $labels.gpu }} の NVLink 帯域が飽和気味",
      "description": "NVLink TX+RX が閾値超で5分継続。テンソル並列の通信ボトルネックの可能性。閾値は GPU のリンク帯域に合わせて調整してください。",
      "enabled": true
    },
    {
      "group": "gpu_health",
      "name": "GPUThermalThrottling",
      "expr": "rate(DCGM_FI_DEV_THERMAL_VIOLATION[5m]) > 0",
      "for": "1m",
      "severity": "critical",
      "summary": "GPU{{ $labels.gpu }} がサーマルスロットリング中",
      "description": "温度制約による周波数低下が継続的に発生しています。冷却/設置/電力設定を確認してください。",
      "enabled": true
    },
    {
      "group": "gpu_health",
      "name": "GPUTemperatureHigh",
      "expr": "DCGM_FI_DEV_GPU_TEMP > 85",
      "for": "2m",
      "severity": "warning",
      "summary": "GPU{{ $labels.gpu }} の温度が高い ({{ $value }}C)",
      "description": "閾値超が2分継続。サーマルスロットリングに至る前の予兆です。",
      "enabled": true
    },
    {
      "group": "gpu_health",
      "name": "GPULowEfficiency",
      "expr": "(avg_over_time(DCGM_FI_PROF_GR_ENGINE_ACTIVE[15m]) < 0.2)\nand\n(avg_over_time(DCGM_FI_DEV_POWER_USAGE[15m]) > 100)",
      "for": "15m",
      "severity": "warning",
      "summary": "GPU{{ $labels.gpu }} の利用効率が低い",
      "description": "電力消費は高い一方で計算エンジン稼働率が15分平均で閾値未満。確保したまま遊んでいる/通信待ち等で効率が悪い可能性。Grafana で SM・Tensor 稼働率の内訳を確認してください。",
      "enabled": true
    },
    {
      "group": "resource_health",
      "name": "HostHighCPU",
      "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100) > 90",
      "for": "5m",
      "severity": "warning",
      "summary": "ホスト {{ $labels.instance }} の CPU 使用率が高い ({{ $value | printf \"%.0f\" }}%)",
      "description": "CPU 使用率が閾値超で5分継続。",
      "enabled": false
    },
    {
      "group": "resource_health",
      "name": "HostHighMemory",
      "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100 > 90",
      "for": "5m",
      "severity": "warning",
      "summary": "ホスト {{ $labels.instance }} のメモリ使用率が高い ({{ $value | printf \"%.0f\" }}%)",
      "description": "メモリ使用率が閾値超で5分継続。",
      "enabled": false
    },
    {
      "group": "resource_health",
      "name": "HostLowDisk",
      "expr": "(node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\"}) * 100 < 10",
      "for": "5m",
      "severity": "critical",
      "summary": "ホスト {{ $labels.instance }} のディスク空きが少ない ({{ $labels.mountpoint }})",
      "description": "ファイルシステム空き容量が閾値未満です。ログ/メトリクスの保持期間を見直してください。",
      "enabled": false
    }
  ]
}